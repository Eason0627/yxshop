    </delete>
    <delete id="deleteProductSales" parameterType="long">
        DELETE FROM product_sales WHERE product_id = #{product_id}
    </delete>
    <delete id="deleteInventory" parameterType="long">
        DELETE FROM inventory WHERE product_id = #{product_id}
    </delete>


<!--    根据id数组批量删除 product_info 商品信息-->
    <delete id="deleteProductInfos" parameterType="java.util.List">
        DELETE FROM product_info WHERE product_id IN
        <foreach item="item" index="index" collection="productIds" open="(" separator="," close=")">
            #{item}
        </foreach>
    </delete>
    <!--    根据id数组批量删除 ProductSales 商品信息-->
