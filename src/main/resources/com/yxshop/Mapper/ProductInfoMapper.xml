<!--    获取品牌、商品、店铺、仓库信息-->
    <select id="getProductCommentByUserId" parameterType="string" resultType="com.yxshop.Entity.VO.BrandInfoVO">
        SELECT DISTINCT
            s.shop_id,
            s.shop_name,
            b.brand_id,
            b.brand_name,
            w.warehouse_id,
            w.warehouse_name
        FROM
            shop s
                LEFT JOIN brand b ON s.shop_id = b.shop_id
                LEFT JOIN warehouse w ON s.owner_user_id = w.user_id
        WHERE
        s.owner_user_id = #{userId}
    </select>
