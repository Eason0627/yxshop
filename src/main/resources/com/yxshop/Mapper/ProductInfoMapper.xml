<!--    根据id查询 product 信息 根据product_id查询 三表（ProductInfo，ProductSales，Inventory）-->
    <select id="getProduct" parameterType="long" resultType="com.yxshop.Entity.Dto.ProductDto">
        SELECT
            p.product_id,
            p.product_name,
            p.description,
            b.brand_id,
            (SELECT b.brand_name FROM brand b WHERE b.brand_id = p.brand_id) as brand_name,
            p.shop_id,

            (SELECT s.shop_name FROM shop s WHERE s.shop_id = p.shop_id) as shop_name,

            p.origin,
            p.material,
            p.size,
            p.color,
            p.weight,
            p.volume,
            p.packaging_details,
            p.warranty_info,
            p.production_date,
            p.expiration_date,

            p.category_id,
            (SELECT c.category_name FROM category c WHERE c.category_id = p.category_id) as category_name,
            p.main_image,
            p.additional_images,
            p.details_images,
            p.tags,
            p.product_status,
            p.createTime,
            p.updateTime,
           i.warehouse_id,
           (SELECT w.warehouse_name FROM warehouse w WHERE w.warehouse_id = i.warehouse_id) as warehouse_name,
           i.stock_quantity,
           i.safety_stock,
           i.last_restock_date,
           i.restock_threshold,
           ps.price,
           ps.cost_price,
           ps.stock_quantity,
           ps.price,
           ps.cost_price,
           ps.sold_quantity,
           ps.reorder_threshold,
           ps.sold_quantity,
           ps.review_count,
           ps.average_rating,
           ps.promotion_details,
           ps.shipping_fee,
           ps.sales_status
        FROM
            product_info p
        LEFT JOIN brand b on p.brand_id = b.brand_id
        LEFT JOIN inventory i ON p.product_id = i.product_id
        LEFT JOIN product_sales ps ON p.product_id = ps.product_id
        WHERE
            p.product_id = #{product_id}

    </select>

    <!--    根据 product 信息 查询 三表（ProductInfo，ProductSales，Inventory）-->
    <select id="getAllProductInfo" parameterType="com.yxshop.Entity.VO.ProductVO" resultType="com.yxshop.Entity.VO.ProductVO">
        SELECT
            p.product_id,
            p.product_name,
            p.description,
            p.brand_id,
            (SELECT b.brand_name FROM brand b WHERE b.brand_id = p.brand_id) as brand_name,
            p.shop_id,
            (SELECT s.shop_name FROM shop s WHERE s.shop_id = p.shop_id) as shop_name,
            p.category_id,
            (SELECT c.category_name FROM category c WHERE c.category_id = p.category_id) as category_name,
            p.main_image,
            p.tags,
            p.product_status,
            i.stock_quantity,
            i.safety_stock,
            ps.price,
            ps.cost_price,
            ps.sold_quantity,
            ps.average_rating,
            ps.sales_status,
            p.updateTime

        FROM
            product_info p
                LEFT JOIN inventory i ON p.product_id = i.product_id
                LEFT JOIN product_sales ps ON p.product_id = ps.product_id
        <where>
            <if test="product_id != null">
                p.product_id = #{product_id}
            </if>

            <if test="product_name != null">
                AND p.product_name LIKE concat('%', #{product_name}, '%')
            </if>

            <if test="brand_id != null">
                AND p.brand_id = #{brand_id}
            </if>
            <if test="shop_id != null">
                AND p.shop_id = #{shop_id}
            </if>
            <if test="category_id != null">
                AND p.category_id = #{category_id}
            </if>
            <if test="sales_status != null">
                AND ps.sales_status = #{sales_status}
            </if>
            <if test="product_status != null">
                AND p.product_status = #{product_status}
            </if>

        </where>
        ORDER BY p.updateTime DESC
    </select>



