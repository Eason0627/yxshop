<!--    private String warehouse_name; // 仓库名称-->
<!--    private String address; // 仓库地址-->
<!--    private String contact_Info; // 仓库的联系信息，如电话号码或电子邮箱-->
<!--    private Integer total_Capacity; // 仓库的总容量，单位通常是立方米或托盘数量-->
<!--    private Integer current_Capacity; // 当前占用的仓库容量，单位与总容量相同-->
<!--    private Integer manager_User_Id; // 仓库经理的用户ID，用于关联仓库经理信息-->
<!--    private LocalDateTime createTime; // 仓库创建的时间戳-->
<!--    private LocalDateTime updateTime; // 仓库信息最后更新的时间戳-->

