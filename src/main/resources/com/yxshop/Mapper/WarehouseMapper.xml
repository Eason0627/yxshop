<!--    Active, Inactive-->
<!--    }-->

<!--    private Status status; // 仓库的状态，活动或非活动-->

<!--    展示当前店铺所有商品的库存信息，支持按条件筛选和排序。-->
    <select id="getAllWarehouse" resultType="com.yxshop.Entity.Pojo.Warehouse">
        SELECT * FROM warehouse
        <where>
            <if test="warehouse_id != null">
                warehouse_id = #{warehouse_id}
            </if>
            <if test="warehouse_name != null">
                AND warehouse_name = #{warehouse_name}
            </if>
            <if test="address != null">
                AND address = #{address}
            </if>
            <if test="contact_Info != null">
                AND contact_Info = #{contact_Info}
            </if>
            <if test="total_Capacity != null">
                AND total_Capacity = #{total_Capacity}
            </if>
            <if test="current_Capacity != null">
                AND current_Capacity = #{current_Capacity}
            </if>
            <if test="manager_User_Id != null">
                AND manager_User_Id = #{manager_User_Id}
            </if>
            <if test="createTime != null">
                AND createTime = #{createTime}
            </if>
            <if test="updateTime != null">
                AND updateTime = #{updateTime}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>

        </where>
    </select>

<!--    动态添加仓库信息，包括仓库名称、地址、联系人信息、总容量、当前容量、经理ID、创建时间、更新时间、状态。-->
    <insert id="addWarehouse" parameterType="com.yxshop.Entity.Pojo.Warehouse">
        INSERT INTO warehouse
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="warehouse_id != null">
                warehouse_id,
            </if>
            <if test="warehouse_name != null">
                warehouse_name,
            </if>
            <if test="address != null">
                address,
            </if>
            <if test="contact_Info != null">
                contact_Info,
            </if>
            <if test="total_Capacity != null">
                total_Capacity,
            </if>
            <if test="current_Capacity !=null">
                current_Capacity,
            </if>
            <if test="manager_User_Id != null">
                manager_User_Id,
            </if>
            <if test="status != null">
                status,
            </if>

        </trim>
        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="warehouse_id != null">
                #{warehouse_id},
            </if>
            <if test="warehouse_name != null">
                #{warehouse_name},
            </if>
            <if test="address != null">
                #{address},
            </if>
            <if test="contact_Info != null">
                #{contact_Info},
            </if>
            <if test="total_Capacity != null">
                #{total_Capacity},
            </if>
            <if test="current_Capacity != null">
                #{current_Capacity},
            </if>
            <if test="manager_User_Id != null">
                #{manager_User_Id},
            </if>
            <if test="status != null">
                #{status},
            </if>
        </trim>

    </insert>


<!--    动态更新仓库信息，包括仓库名称、地址、联系人信息、总容量、当前容量、经理ID、更新时间、状态。-->
    <update id="updateWarehouse" parameterType="com.yxshop.Entity.Pojo.Warehouse">
        UPDATE warehouse
        <set>
            <if test="warehouse_name != null">
                warehouse_name = #{warehouse_name},
            </if>
            <if test="address != null">
                address = #{address},
            </if>
            <if test="contact_Info != null">
                contact_Info = #{contact_Info},
            </if>
            <if test="total_Capacity != null">
                total_Capacity = #{total_Capacity},
            </if>
            <if test="current_Capacity != null">
                current_Capacity = #{current_Capacity},
            </if>
            <if test="manager_User_Id != null">
                manager_User_Id = #{manager_User_Id},
            </if>
        </set>
        WHERE warehouse_id = #{warehouse_id}
    </update>
</mapper>