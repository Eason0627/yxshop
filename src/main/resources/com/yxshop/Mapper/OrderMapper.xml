    <!--    插入订单-->
    <insert id="addOrder" parameterType="com.yxshop.Entity.Pojo.OrderInfo">
        INSERT INTO order_info(
                               order_id,
                               customer_id,
                               shop_id,
                               product_id,
                               quantity,
                               order_total,
                               freight,
                               disbursements,
                               integral,
                               payment_method,
                               alipay_number,
                               order_status,
                               payment_status,
                               shipping_address,
                               billing_address,
                               payTime,
                               transactionTime,
                               comments)
        VALUES (
                #{order_id},
                #{customer_id},
                #{shop_id},
                #{product_id},
                #{quantity},
                #{order_total},
                #{freight},
                #{disbursements},
                #{integral},
                #{payment_method},
                #{alipay_number},
                #{order_status},
                #{payment_status},
                #{shipping_address},
                #{billing_address},
                #{payTime},
                #{transactionTime},
                #{comments}
               )
    </insert>


    <!--    动态更新订单-->
    <update id="updateOrderById" parameterType="com.yxshop.Entity.Pojo.OrderInfo">
        UPDATE order_info
        <set>
            <if test="order_total != null">
                order_total = #{order_total},
            </if>
            <if test="order_status != null">
                order_status = #{order_status},
            </if>
            <if test="payment_status != null">
                payment_status = #{payment_status},
            </if>
            <if test="shipping_address != null">
                shipping_address = #{shipping_address},
            </if>
            <if test="billing_address != null">
                billing_address = #{billing_address},
            </if>
            <if test="comments != null">
                comments = #{comments},
            </if>
        </set>
        WHERE order_id = #{order_id}
    </update>


    <!--    批量逻辑删除订单-->
    <update id="deleteOrders">
        UPDATE order_info
        SET order_status = 'Cancelled'
        WHERE order_id IN
        <foreach collection="order_id" item="order_id" open="(" separator="," close=")">
            #{order_id}
        </foreach>
    </update>

    <select id="getOrderNumByStatus" parameterType="java.lang.Long" resultType="java.util.Map">
        select order_status,COUNT(order_status) statusNum from order_info
        where shop_id = #{shopId}
        group by order_status
    </select>


    <select id="getTodayOrderNum" resultType="java.util.Map">
        SELECT
            COUNT(*) AS totalOrders,
            SUM(CASE WHEN DATE_FORMAT(createTime, '%Y-%m-%d') = DATE_FORMAT(NOW(), '%Y-%m-%d') THEN 1 ELSE 0 END) AS todayOrders
        FROM order_info
        WHERE shop_id = #{shopId}
    </select>



</mapper>