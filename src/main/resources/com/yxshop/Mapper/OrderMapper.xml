    <!-- 动态条件查询 -->
    <select id="getAllOrders" resultType="com.yxshop.Entity.Pojo.OrderInfo">
        SELECT * FROM order_info
        <where>
        1=1
            <if test="order_id != null">
              AND  order_id = #{order_id}
            </if>
            <if test="customer_id != null">
                AND customer_id = #{customer_id}
            </if>
            <if test="order_total != null">
                AND order_total = #{order_total}
            </if>
            <if test="order_status != null">
                AND order_total = #{order_total}
            </if>
            <if test="payment_status != null">
                AND order_status = #{order_status}
            </if>
            <if test="shipping_address != null">
                AND shipping_address = #{shipping_address}
            </if>
            <if test="billing_address != null">
                AND billing_address = #{billing_address}
            </if>
            <if test="comments != null">
                AND comments = #{comments}
            </if>

        </where>
    </select>


