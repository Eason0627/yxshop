<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yxshop.Mapper.PromotionTypeMapper">
<!--    动态查询促销信息-->
    <select id="getPromotionTypes" parameterType="com.yxshop.Entity.Pojo.PromotionType" resultType="com.yxshop.Entity.Pojo.PromotionType">
        SELECT * FROM promotion_type
        <where>
            <if test="type_id != null">
                type_id = #{type_id}
            </if>
            <if test="name != null">
                AND name = #{name}
            </if>
            <if test="description != null">
                AND description = #{description}
           </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
    </select>


<!--    动态更新促销类型信息-->
    <update id="updatePromotionType" parameterType="com.yxshop.Entity.Pojo.PromotionType">
        UPDATE promotion_type
        <set>
            <if test="name != null">
                name = #{name},
            </if>
            <if test="shop_id != null">
                shop_id = #{shop_id},
            </if>
            <if test="description != null">
                description = #{description},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
        </set>
        WHERE type_id = #{type_id}
    </update>
</mapper>